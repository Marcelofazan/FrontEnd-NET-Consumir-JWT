@model consumirAPI.Models.Produto

@{
    ViewData["Title"] = "Deletar";
}

@if (ViewBag.Erro != null)
{
    <div class="alert alert-danger">@ViewBag.Erro</div>
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Produto</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IdEmpresa)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IdEmpresa)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IdProduto)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IdProduto)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ValorUltimaCompra)
        </dt>
        <dd class="col-sm-10">
            @Model.ValorUltimaCompra.ToString("C")
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.LucroMinimo)
        </dt>
        <dd class="col-sm-10">
            @Model.LucroMinimo.ToString("C")
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.LucroMaximo)
        </dt>
        <dd class="col-sm-10">
            @Model.LucroMaximo.ToString("C")
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PrecoVendaMinimo)
        </dt>
        <dd class="col-sm-10">
            @Model.PrecoVendaMinimo.ToString("C")
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PrecoSugerido)
        </dt>
        <dd class="col-sm-10">
            @Model.PrecoSugerido.ToString("C")
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DataCadastro)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DataCadastro)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
